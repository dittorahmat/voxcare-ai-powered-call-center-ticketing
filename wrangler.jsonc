{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "voxcare-taqj9oa2s4uxvtewbgw3c",
	"main": "worker/index.ts",
	"compatibility_date": "2025-04-24",
	"compatibility_flags": ["nodejs_compat"],
	"durable_objects": {
		"bindings": [
			{
				"name": "CHAT_AGENT",
				"class_name": "ChatAgent"
			},
			{
				"name": "APP_CONTROLLER",
				"class_name": "AppController"
			},
			{
				"name": "AUTH_CONTROLLER",
				"class_name": "AuthController"
			},
			{
				"name": "RATE_LIMITER",
				"class_name": "RateLimiter"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["ChatAgent"]
		},
		{
			"tag": "v2",
			"new_classes": ["AppController"]
		},
		{
			"tag": "v3",
			"new_classes": ["AuthController"]
		},
		{
			"tag": "v4",
			"new_classes": ["RateLimiter"]
		},
		{
			"tag": "v5",
			"new_classes": ["AppControllerV5"]
		}
	],
	"assets": {
		"not_found_handling": "single-page-application",
		"run_worker_first": ["/api/*", "!/api/docs/*"]
	},
	"observability": {
		"enabled": true
	},
	"vars": {
		"CF_AI_BASE_URL": "https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/YOUR_GATEWAY_ID/openai",
		"CF_AI_API_KEY": "your-cloudflare-api-key",
		"JWT_SECRET": "dev-secret-change-me-in-production",
		"WAHA_URL": "http://localhost:3000",
		"WAHA_API_KEY": "your-waha-api-key"
	},
	/*
	 * R2 bucket for file attachments.
	 * Create a bucket: wrangler r2 bucket create voxcare-attachments
	 * Then uncomment the block below.
	 */
	"r2_buckets": [
		{
			"binding": "ATTACHMENTS_BUCKET",
			"bucket_name": "voxcare-attachments",
			"preview_bucket_name": "voxcare-attachments-preview"
		}
	],
	"kv_namespaces": [
		{
			"binding": "KNOWLEDGE_BASE_KV",
			"id": "your-kv-namespace-id",
			"preview_id": "your-preview-kv-namespace-id"
		}
	],
	"triggers": {
		"crons": [
			"*/30 * * * *",
			"0 */6 * * *",
			"0 3 * * *",
			"0 9 * * *"
		]
	}
}
